{
  "name": "cat-offline-calculator",
  "version": "1.0.0",
  "description": "Offline CAT-style floating calculator for desktop exam practice.",
  "author": "Devang Joshi",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/coderdevang/CAT-offline-calculator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderdevang/CAT-offline-calculator.git"
  },
  "bugs": {
    "url": "https://github.com/coderdevang/CAT-offline-calculator/issues"
  },
  "keywords": [
    "cat",
    "calculator",
    "exam-practice",
    "offline",
    "electron",
    "vite",
    "desktop-app"
  ],
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173/src/index.html && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173/src/index.html electron .",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:electron && vite build",
    "dist": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "jquery": "^3.7.1"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/jquery": "^4.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.catpractice.calculator2026",
    "productName": "CAT On-Screen Calculator 2026",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.education"
    },
    "linux": {
      "target": "AppImage",
      "category": "Education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
